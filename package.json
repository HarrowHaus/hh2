{
  "name": "hh2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "THE HAND-ME-DOWN — a browser-based Windows XP desktop (portfolio-OS).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "ingest": "node scripts/ingest-music.mjs",
    "typecheck": "tsc -b --noEmit",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=hh2"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
